# One terminal for web + ML: `npm run dev:stack`
# If port 3000 is busy (EADDRINUSE): use `npm run dev:alt` or set PORT=3001
# If port 8000 is busy: run `npm run dev:ml:alt` and set ML_BACKEND_URL=http://127.0.0.1:8001

# ML backend (Render): public URL of the FastAPI service — no trailing slash.
# When set at build time, the browser calls this origin directly (CORS must allow your frontend).
# Local `npm run dev`: if unset, the app uses same-origin `/api/ml` → Express → ML_BACKEND_URL (avoids stale :8000).
# Set VITE_ML_BACKEND_URL only if the browser must call FastAPI directly (e.g. separate Render ML URL).
VITE_ML_BACKEND_URL=

# Render (ML Web Service) — Root Directory: ml-backend
# Start Command:
#   uvicorn main:app --host 0.0.0.0 --port $PORT
# Build Command: (none) — Python from requirements.txt

# Set to "true" to skip the Google login screen (local dev / demos). Same as clicking
# "Continue without Google" on the login page.
VITE_SKIP_AUTH=

# Used by server.ts for /api/ml → FastAPI when the browser does NOT use VITE_ML_BACKEND_URL.
# Local: start FastAPI (npm run dev:ml) then keep this as:
ML_BACKEND_URL=http://127.0.0.1:8000

# FastAPI (Render): set on the ML service as comma-separated allowed browser origins, e.g.
# CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000

# GEMINI_API_KEY: Required for Gemini triage in ml-backend (or use GOOGLE_API_KEY).
# Optional: GEMINI_TRIAGE_MODEL — e.g. gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY=MY_GEMINI_API_KEY
GEMINI_TRIAGE_MODEL=gemini-2.0-flash
# Hackathon demo: skip Gemini entirely (instant rule-based triage). Values: 1, true, yes
MEDIVOICE_TRIAGE_RULES_ONLY=
# Optional: thread timeout for Gemini call in seconds (default ~48; must stay below browser ~55s)
GEMINI_THREAD_TIMEOUT=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MediVoice `backend/` Voice: public https base (ngrok / Render) — no trailing slash. Required for Gather + outbound.
PUBLIC_BASE_URL=

# Optional: Twilio Voice JS SDK (browser “Dial from browser”) — create API Key + TwiML App in Twilio Console.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_VOICE_APP_SID=

# ElevenLabs Credentials
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
