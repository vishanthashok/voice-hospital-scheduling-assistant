# One terminal for web + ML: `npm run dev:stack`
# If port 3000 is busy (EADDRINUSE): use `npm run dev:alt` or set PORT=3001
# If port 8000 is busy: run `npm run dev:ml:alt` and set ML_BACKEND_URL=http://127.0.0.1:8001

# ML backend (Render): public URL of the FastAPI service — no trailing slash.
# When set at build time, the browser calls this origin directly (CORS must allow your frontend).
# Local `npm run dev`: if unset, the app uses same-origin `/api/ml` → Express → ML_BACKEND_URL (avoids stale :8000).
# Set VITE_ML_BACKEND_URL only if the browser must call FastAPI directly (e.g. separate Render ML URL).
VITE_ML_BACKEND_URL=
VITE_SCHEDULING_API_URL=
# Leave empty locally to use the Express proxy at /api/scheduling/* (see server.ts).
SCHEDULING_API_URL=http://localhost:8001

# Render (ML Web Service) — Root Directory: ml-backend
# Start Command:
#   uvicorn main:app --host 0.0.0.0 --port $PORT
# Build Command: (none) — Python from requirements.txt

# Set to "true" to skip the Google login screen (local dev / demos). Same as clicking
# "Continue without Google" on the login page.
VITE_SKIP_AUTH=

# Used by server.ts for /api/ml → FastAPI when the browser does NOT use VITE_ML_BACKEND_URL.
# Local: start FastAPI (npm run dev:ml) then keep this as:
ML_BACKEND_URL=http://127.0.0.1:8000

# FastAPI (Render): set on the ML service as comma-separated allowed browser origins, e.g.
# CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000

# GEMINI_API_KEY: Required for Gemini triage in ml-backend (or use GOOGLE_API_KEY).
# Optional: GEMINI_TRIAGE_MODEL — e.g. gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY=MY_GEMINI_API_KEY
GEMINI_TRIAGE_MODEL=gemini-2.0-flash
# Hackathon demo: skip Gemini entirely (instant rule-based triage). Values: 1, true, yes
MEDIVOICE_TRIAGE_RULES_ONLY=
# Optional: thread timeout for Gemini call in seconds (default ~48; must stay below browser ~55s)
GEMINI_THREAD_TIMEOUT=

# --- MediVoice API (backend/) — triage: AWS Bedrock OR Google Gemini ---
# TRIAGE_BACKEND=auto|bedrock|gemini  (auto prefers Bedrock if BEDROCK_MODEL_ID is set)
TRIAGE_BACKEND=auto
# Claude on Bedrock (example). Enable model in AWS Console → Bedrock → Model access.
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1
# Auth — use ONE of:
# (A) Short-term API key from Bedrock console → API keys (expires, e.g. 12h). Boto3 reads this automatically:
AWS_BEARER_TOKEN_BEDROCK=
# (B) IAM access keys with bedrock:InvokeModel:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional if using Bedrock only — leave GEMINI_API_KEY empty.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio toll-free number in E.164 format:
TWILIO_PHONE_NUMBER=+18332082827
TWILIO_SMS_ENABLED=false

# MediVoice `backend/` Voice: public https base (ngrok / Render) — no trailing slash. Required for Gather + outbound.
PUBLIC_BASE_URL=

# Optional: Twilio Voice JS SDK (browser “Dial from browser”) — create API Key + TwiML App in Twilio Console.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_VOICE_APP_SID=

# ElevenLabs Credentials
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ==========================
# FastAPI scheduling backend
# ==========================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=sqlite:///./db/app.db

# Fish Audio speech-to-text
FISH_AUDIO_API_KEY=
FISH_AUDIO_BASE_URL=https://api.fish.audio
# Optional: set explicitly for lower-cost/faster transcription on short English calls.
FISH_AUDIO_LANGUAGE=en
# Keep true on free tier to reduce latency.
FISH_AUDIO_IGNORE_TIMESTAMPS=true

# Google Calendar integration
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json
GOOGLE_CALENDAR_ID=

# SMTP integration (Gmail app password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=
SMTP_APP_PASSWORD=
